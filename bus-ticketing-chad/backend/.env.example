# Backend Environment Configuration for Chad Bus Ticketing System

# Server Configuration
NODE_ENV=development
PORT=5000
API_BASE_URL=http://localhost:5000

# Database Configuration (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/bus_ticketing_chad?schema=public"

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# OTP Configuration
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6

# WhatsApp Configuration (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_SMS_NUMBER=+1234567890

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM="Chad Bus Ticketing <noreply@chadbusticketing.com>"

# Mobile Money Configuration
# These are placeholders - integrate with actual MoMo API providers in Chad
MOMO_AIRTEL_API_KEY=your_airtel_api_key
MOMO_AIRTEL_API_SECRET=your_airtel_secret
MOMO_MOOV_API_KEY=your_moov_api_key
MOMO_MOOV_API_SECRET=your_moov_secret

# Payment Configuration
PAYMENT_RESERVATION_HOURS=24
PAYMENT_WEBHOOK_SECRET=your_webhook_secret

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# Frontend URL (for CORS and notifications)
FRONTEND_URL=http://localhost:3000

# Booking Configuration
BOOKING_CODE_LENGTH=6
SEAT_RESERVATION_MINUTES=15

# System Defaults
DEFAULT_LUGGAGE_FREE_WEIGHT=20
DEFAULT_LUGGAGE_EXTRA_FEE_PER_KG=500
DEFAULT_CURRENCY=FCFA
