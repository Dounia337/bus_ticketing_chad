// Prisma schema for Chad Bus Ticketing System
// Designed for PostgreSQL with mobile-first operations in mind

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User roles: USER (passenger), ADMIN (system admin), AGENT (bus operator/sales agent)
enum UserRole {
  USER
  ADMIN
  AGENT
}

// Bus operational status
enum BusStatus {
  AVAILABLE
  FULL
  MAINTENANCE
  INACTIVE
}

// Bus physical condition
enum BusCondition {
  GOOD
  AVERAGE
  POOR
}

// Trip lifecycle states
enum TripStatus {
  SCHEDULED
  BOARDING
  DEPARTED
  ARRIVED
  CANCELLED
  DELAYED
}

// Booking states
enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  EXPIRED
}

// Payment states - critical for manual confirmation workflow
enum PaymentStatus {
  PENDING
  PAID
  FAILED
  RESERVED
  REFUNDED
}

// Payment methods available in Chad
enum PaymentMethod {
  MOMO_AIRTEL
  MOMO_MOOV
  MOMO_TIGO
  CASH
  BANK_TRANSFER
}

// Notification delivery channels
enum NotificationChannel {
  WHATSAPP
  SMS
  EMAIL
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  DELIVERED
}

// Users table - supports both registered users and guest bookings
model User {
  id           String   @id @default(uuid())
  fullName     String   @map("full_name")
  phoneNumber  String   @unique @map("phone_number") // Primary identifier for Chad
  email        String?  @unique // Optional - many users won't have email
  password     String?  // Hashed password, null for guest users
  role         UserRole @default(USER)
  isActive     Boolean  @default(true) @map("is_active")
  lastOtp      String?  @map("last_otp") // For phone verification
  otpExpiresAt DateTime? @map("otp_expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  bookings     Booking[]
  
  @@map("users")
}

// Routes define city-to-city connections with base pricing
model Route {
  id              String   @id @default(uuid())
  originCity      String   @map("origin_city") // e.g., "N'Djamena"
  destinationCity String   @map("destination_city") // e.g., "Moundou"
  basePrice       Int      @map("base_price") // In FCFA
  distance        Int?     // In kilometers
  estimatedDuration Int?   @map("estimated_duration") // In minutes
  isActive        Boolean  @default(true) @map("is_active")
  description     String?  // Optional route notes
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  trips           Trip[]
  
  @@unique([originCity, destinationCity])
  @@map("routes")
}

// Buses are physical vehicles in the fleet
model Bus {
  id              String       @id @default(uuid())
  busNumber       String       @unique @map("bus_number") // Vehicle registration/identifier
  capacity        Int          // Total number of seats
  plateNumber     String?      @unique @map("plate_number")
  status          BusStatus    @default(AVAILABLE)
  condition       BusCondition @default(GOOD)
  model           String?      // Bus make/model
  yearManufactured Int?        @map("year_manufactured")
  lastMaintenance DateTime?    @map("last_maintenance")
  isActive        Boolean      @default(true) @map("is_active")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  // Relations
  seats           Seat[]
  trips           Trip[]
  
  @@map("buses")
}

// Seats represent individual seats on a bus
// Seat layout is simple: numbered 1 to capacity
model Seat {
  id         String   @id @default(uuid())
  busId      String   @map("bus_id")
  seatNumber Int      @map("seat_number") // 1, 2, 3, etc.
  isActive   Boolean  @default(true) @map("is_active") // Can disable specific seats
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  bus        Bus      @relation(fields: [busId], references: [id], onDelete: Cascade)
  passengers Passenger[]
  
  @@unique([busId, seatNumber])
  @@map("seats")
}

// Trips are scheduled journeys on specific routes
model Trip {
  id              String     @id @default(uuid())
  routeId         String     @map("route_id")
  busId           String     @map("bus_id")
  departureDate   DateTime   @map("departure_date") // Date of departure
  departureTime   String     @map("departure_time") // Time in HH:mm format
  arrivalTime     String?    @map("arrival_time") // Estimated arrival time
  availableSeats  Int        @map("available_seats") // Decremented as bookings are made
  currentPrice    Int        @map("current_price") // Can differ from base_price (surge pricing, discounts)
  status          TripStatus @default(SCHEDULED)
  boardingPoint   String?    @map("boarding_point") // Specific location in origin city
  remarks         String?    // Special notes (delay reason, etc.)
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  // Relations
  route           Route      @relation(fields: [routeId], references: [id], onDelete: Restrict)
  bus             Bus        @relation(fields: [busId], references: [id], onDelete: Restrict)
  bookings        Booking[]
  
  @@index([departureDate, status])
  @@index([routeId, departureDate])
  @@map("trips")
}

// Bookings represent a reservation made by a user
model Booking {
  id                String        @id @default(uuid())
  bookingCode       String        @unique @map("booking_code") // 6-char alphanumeric
  userId            String?       @map("user_id") // Null for guest bookings
  tripId            String        @map("trip_id")
  contactName       String        @map("contact_name") // For guest bookings
  contactPhone      String        @map("contact_phone") // For notifications
  contactEmail      String?       @map("contact_email")
  totalPassengers   Int           @map("total_passengers")
  totalPrice        Int           @map("total_price") // In FCFA
  luggagePrice      Int           @default(0) @map("luggage_price") // Extra luggage fees
  status            BookingStatus @default(PENDING)
  paymentStatus     PaymentStatus @default(PENDING) @map("payment_status")
  paymentMethod     PaymentMethod? @map("payment_method")
  reservedUntil     DateTime?     @map("reserved_until") // For "pay later" bookings
  notes             String?       // Admin notes or special requests
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  // Relations
  user              User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  trip              Trip          @relation(fields: [tripId], references: [id], onDelete: Restrict)
  passengers        Passenger[]
  luggage           Luggage?
  payments          Payment[]
  notifications     Notification[]
  
  @@index([bookingCode])
  @@index([contactPhone])
  @@index([tripId, status])
  @@map("bookings")
}

// Passengers represent individual travelers on a booking
model Passenger {
  id         String   @id @default(uuid())
  bookingId  String   @map("booking_id")
  seatId     String   @map("seat_id")
  fullName   String   @map("full_name")
  age        Int?     // Optional, useful for child discounts
  idNumber   String?  @map("id_number") // National ID or passport
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  seat       Seat     @relation(fields: [seatId], references: [id], onDelete: Restrict)
  
  @@map("passengers")
}

// Luggage tracking and fee calculation
model Luggage {
  id              String   @id @default(uuid())
  bookingId       String   @unique @map("booking_id")
  numberOfBags    Int      @map("number_of_bags")
  estimatedWeight Float    @map("estimated_weight") // In kilograms
  freeWeightLimit Float    @default(20.0) @map("free_weight_limit") // Kg per passenger
  extraFeePerKg   Float    @default(500.0) @map("extra_fee_per_kg") // FCFA
  totalExtraFee   Int      @default(0) @map("total_extra_fee") // Calculated fee
  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  booking         Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  
  @@map("luggage")
}

// Payments track all payment attempts and confirmations
model Payment {
  id                    String        @id @default(uuid())
  bookingId             String        @map("booking_id")
  amount                Int           // In FCFA
  method                PaymentMethod
  status                PaymentStatus @default(PENDING)
  transactionReference  String?       @unique @map("transaction_reference") // MoMo transaction ID
  phoneNumber           String?       @map("phone_number") // Phone used for MoMo
  confirmedBy           String?       @map("confirmed_by") // Admin ID who manually confirmed
  confirmedAt           DateTime?     @map("confirmed_at")
  failureReason         String?       @map("failure_reason")
  metadata              String?       // JSON string for additional data
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  // Relations
  booking               Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  
  @@index([transactionReference])
  @@map("payments")
}

// System configuration for luggage rules, pricing, etc.
model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique // e.g., "luggage_free_weight", "luggage_extra_fee"
  value     String   // JSON-serialized value
  category  String   // e.g., "LUGGAGE", "PRICING", "SYSTEM"
  updatedAt DateTime @updatedAt @map("updated_at")
  
  @@map("system_config")
}

// Notification log for tracking all communications
model Notification {
  id         String             @id @default(uuid())
  bookingId  String             @map("booking_id")
  channel    NotificationChannel
  recipient  String             // Phone number or email
  messageKey String             @map("message_key") // e.g., "BOOKING_CONFIRMED"
  content    String             // Actual message sent (in French)
  status     NotificationStatus @default(PENDING)
  sentAt     DateTime?          @map("sent_at")
  deliveredAt DateTime?         @map("delivered_at")
  errorMessage String?          @map("error_message")
  createdAt  DateTime           @default(now()) @map("created_at")

  // Relations
  booking    Booking            @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  
  @@index([bookingId])
  @@map("notifications")
}

// Audit log for critical operations (admin actions, payment confirmations)
model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id") // Who performed the action
  action    String   // e.g., "PAYMENT_CONFIRMED", "BOOKING_CANCELLED"
  entityType String  @map("entity_type") // e.g., "Booking", "Trip"
  entityId  String   @map("entity_id")
  details   String?  // JSON-serialized details
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")
  
  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
